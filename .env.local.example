# Local development override
# Copy to .env.local and use when running services outside Docker (e.g., npm run dev)
# The gateway and services run on localhost; Docker hostnames (auth-service, crm-service, etc.) do not resolve.
#
# Required for Users/Roles CRUD: AUTH_SERVICE_URL must point to auth-service (default port 3001)

AUTH_SERVICE_URL=http://localhost:3001
CRM_SERVICE_URL=http://localhost:3002
FINANCE_SERVICE_URL=http://localhost:3003
HR_SERVICE_URL=http://localhost:3004
INVENTORY_SERVICE_URL=http://localhost:3005
ACCOUNTING_SERVICE_URL=http://localhost:3006
NOTIFICATION_SERVICE_URL=http://localhost:3011
MANUFACTURING_SERVICE_URL=http://localhost:3012
ASSET_SERVICE_URL=http://localhost:3013
ANALYTICS_SERVICE_URL=http://localhost:3010
