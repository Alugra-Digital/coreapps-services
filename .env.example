# ─── Database ─────────────────────────────────────────────────────────
DB_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
DB_HOST=YOUR_DB_HOST_IP
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=YOUR_REDIS_HOST_IP
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password-here

# ─── JWT ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=8h
# Generate with: openssl rand -hex 64  (different value from JWT_SECRET)
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_BYTE_HEX_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO Object Storage ──────────────────────────────────────────────
MINIO_ENDPOINT=YOUR_MINIO_HOST_IP
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-strong-minio-secret-key
MINIO_BUCKET_NAME=coreapps

S3_ENDPOINT=https://YOUR_MINIO_HOST_IP:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-strong-minio-secret-key
S3_BUCKET=coreapps
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-production-domain.com

# ─── Gateway ──────────────────────────────────────────────────────────
GATEWAY_PORT=3000

# ─── Service URLs (internal Docker network) ───────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
CRM_SERVICE_URL=http://crm-service:3002
FINANCE_SERVICE_URL=http://finance-service:3003
HR_SERVICE_URL=http://hr-service:3004
INVENTORY_SERVICE_URL=http://inventory-service:3005
ACCOUNTING_SERVICE_URL=http://accounting-service:3006
ANALYTICS_SERVICE_URL=http://analytics-service:3010
NOTIFICATION_SERVICE_URL=http://notification-service:3011
MANUFACTURING_SERVICE_URL=http://manufacturing-service:3012
ASSET_SERVICE_URL=http://asset-service:3013
INTEGRATION_SERVICE_URL=http://integration-service:3014
INTEGRATION_SERVICE_PORT=3014

# ─── Third-party integrations (integration-service) ───────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
XENDIT_SECRET_KEY=your-xendit-secret-key

# ─── Node ─────────────────────────────────────────────────────────────
NODE_ENV=production
